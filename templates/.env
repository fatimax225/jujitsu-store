# ── Local development only ──────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in values below
# 3. NEVER commit .env to Git  (it's in .gitignore)
#
# On Render: set these in Dashboard → Your Service → Environment

# Leave blank → uses local SQLite (jujita_local.db) automatically
DATABASE_URL=

# Paste your Render PostgreSQL URL here to test locally:
# DATABASE_URL=postgresql://jujita_db_user:PASSWORD@host/jujita_db

SECRET_KEY=change_me_to_something_long_and_random

ADMIN_USERNAME=jojo
ADMIN_PASSWORD=2256
